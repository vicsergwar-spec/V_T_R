# API Keys para V_T_R - Video Transcriptor y Resumen
# Copia este archivo como .env y reemplaza con tus API keys reales

# Obligatorio: API Key de Google Gemini
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Opcional: API Key de OpenAI (para usar Whisper API como respaldo)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_api_key_de_openai_aqui_opcional
